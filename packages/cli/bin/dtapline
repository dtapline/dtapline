#!/usr/bin/env node
"use strict"

/**
 * dtapline — platform binary resolver
 *
 * This is a plain Node.js CJS script (no dependencies, no transpilation).
 * It locates the prebuilt native binary for the current OS/arch inside
 * node_modules and delegates execution to it.
 *
 * The native binaries live in optionalDependency packages named:
 *   @dtapline/cli-<os>-<arch>
 *
 * npm/pnpm/yarn installs only the matching os+cpu package at install time
 * (because they are listed as optionalDependencies and each sub-package has
 * "os" and "cpu" fields that restrict installation to the matching platform).
 *
 * Override with env var:  DTAPLINE_BIN_PATH=/path/to/dtapline
 */

const childProcess = require("child_process")
const fs = require("fs")
const path = require("path")
const os = require("os")

function run(target) {
  const result = childProcess.spawnSync(target, process.argv.slice(2), {
    stdio: "inherit",
  })
  if (result.error) {
    console.error(result.error.message)
    process.exit(1)
  }
  process.exit(typeof result.status === "number" ? result.status : 0)
}

// Escape hatch: explicit binary path via env var
const envPath = process.env.DTAPLINE_BIN_PATH
if (envPath) {
  run(envPath)
}

// Map Node.js platform/arch to our package naming convention
const platformMap = { darwin: "darwin", linux: "linux" }
const archMap = { x64: "x64", arm64: "arm64" }

const platform = platformMap[os.platform()]
const arch = archMap[os.arch()]

if (!platform || !arch) {
  console.error(
    `dtapline: unsupported platform ${os.platform()}-${os.arch()}\n` +
      `Supported platforms: darwin-arm64, darwin-x64, linux-arm64, linux-x64`,
  )
  process.exit(1)
}

// Expected package name prefix, e.g. "@dtapline/cli-darwin-arm64"
const base = `@dtapline/cli-${platform}-${arch}`
const binary = "dtapline"

/**
 * Walk up the directory tree from startDir looking for a node_modules directory
 * that contains a matching @dtapline/cli-<platform>-<arch> package.
 */
function findBinary(startDir) {
  let current = startDir
  for (;;) {
    // Check both scoped (@dtapline/cli-darwin-arm64) and flat layouts
    const scopedPath = path.join(current, "node_modules", "@dtapline", `cli-${platform}-${arch}`, "bin", binary)
    if (fs.existsSync(scopedPath)) {
      return scopedPath
    }

    const parent = path.dirname(current)
    if (parent === current) {
      // Reached filesystem root
      return undefined
    }
    current = parent
  }
}

const resolved = findBinary(path.dirname(fs.realpathSync(__filename)))

if (!resolved) {
  console.error(
    `dtapline: could not find the native binary for ${platform}-${arch}.\n\n` +
      `Expected package: ${base}\n\n` +
      `If you installed dtapline with npm/pnpm/yarn, this usually means the\n` +
      `optional dependency for your platform was not installed. Try:\n\n` +
      `  npm install ${base}\n\n` +
      `Or set DTAPLINE_BIN_PATH=/path/to/dtapline to point directly to a binary.`,
  )
  process.exit(1)
}

run(resolved)
