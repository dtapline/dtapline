{
  "extends": "../../tsconfig.base.json",
  "references": [
    { "path": "../domain/tsconfig.build.json" }
  ],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
