{
  "name": "@dtapline/cli",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Dtapline CLI for deployment reporting",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "packages/cli"
  },
  "bin": {
    "dtapline": "./dist/index.js",
    "dtap": "./dist/index.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=cjs --banner:js=\"#!/usr/bin/env node\"",
    "clean": "rm -rf dist",
    "check": "tsc -b tsconfig.json",
    "test": "vitest"
  },
  "dependencies": {
    "@dtapline/domain": "workspace:^",
    "@effect/cli": "^0.73.1",
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "effect": "^3.19.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0"
  }
}
