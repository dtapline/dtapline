# API URL for Better Auth and API calls
# In development, leave empty to use Vite proxy (cookies work correctly)
# In production, set to the actual API URL (e.g., https://api.dtapline.com)
# VITE_API_BASE_URL=

# Feature flags
# Disable social login (GitHub OAuth)
# Set to 'true' to hide social login buttons (e.g., on netlify.app subdomains where OAuth doesn't work)
# Default: false (social login enabled)
# VITE_DISABLE_SOCIAL_LOGIN=false
