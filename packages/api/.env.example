# ===================================
# Dtapline Server Configuration
# ===================================

# MongoDB Connection
# ----------------------------------
# Production: Use MongoDB Atlas connection string
# Local: Use local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/dtapline

# Server Configuration
# ----------------------------------
PORT=3000

# CORS Configuration
# ----------------------------------
# Comma-separated list of allowed origins
# For development, you can use http://localhost:5173 (Vite default)
# For production, use your actual frontend domain
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication (Better Auth)
# ----------------------------------
# Secret key for signing JWT tokens and session cookies
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Base URL for authentication callbacks
# For local development, use http://localhost:3000
# For production, use your actual domain
AUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
# Get credentials at: https://github.com/settings/developers
# Uncomment and fill in your credentials to enable GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
