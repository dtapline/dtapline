# ===================================
# Dtapline Server Configuration
# ===================================

# MongoDB Connection
# ----------------------------------
# Production: Use MongoDB Atlas connection string
# Local: Use local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/dtapline

# CORS Configuration
# ----------------------------------
# Comma-separated list of allowed origins for CORS and OAuth callbacks
# IMPORTANT: Include your frontend URL here for OAuth to work properly
# For development, you MUST include http://localhost:5173 (Vite default)
# For production, use your actual frontend domain (e.g., https://yourdomain.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication (Better Auth)
# ----------------------------------
# Secret key for signing JWT tokens and session cookies
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Base URL for authentication callbacks (Backend API URL)
# For local development, use http://localhost:3000
# For production, use your actual API domain (e.g., https://api.yourdomain.com)
AUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
# ----------------------------------
# To enable GitHub OAuth, create an OAuth App at: https://github.com/settings/developers
# 
# Configuration for local development:
#   - Application name: Dtapline (Development)
#   - Homepage URL: http://localhost:5173
#   - Authorization callback URL: http://localhost:3000/api/auth/callback/github
#
# Configuration for production:
#   - Application name: Dtapline
#   - Homepage URL: https://yourdomain.com
#   - Authorization callback URL: https://api.yourdomain.com/api/auth/callback/github
#
# After creating the OAuth app, uncomment and fill in your credentials:
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
