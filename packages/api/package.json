{
  "name": "@dtapline/api",
  "version": "0.4.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "The Dtapline API server",
  "repository": {
    "type": "git",
    "url": "https://github.com/dtapline/dtapline.git",
    "directory": "packages/api"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "check-mongo": "node scripts/check-mongo.mjs",
    "seed:demo": "tsx scripts/seed-demo-user.ts",
    "build": "tsup",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.990.0",
    "@aws-sdk/client-dynamodb": "^3.990.0",
    "@aws-sdk/lib-dynamodb": "^3.990.0",
    "@dtapline/domain": "workspace:^",
    "@effect-aws/client-api-gateway-management-api": "^1.10.9",
    "@effect-aws/client-dynamodb": "^1.10.9",
    "@effect-aws/dynamodb": "^1.0.3",
    "@effect-aws/lambda": "^1.5.2",
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "aws4": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "effect": "^3.19.15",
    "mongodb": "^7.0.0",
    "socks": "^2.8.7",
    "ws": "^8.19.0"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/bcryptjs": "^3.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.5"
  }
}
