{
  "name": "@dtapline/api",
  "version": "0.2.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "The Dtapline API server",
  "repository": {
    "type": "git",
    "url": "https://github.com/dtapline/dtapline.git",
    "directory": "packages/api"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "check-mongo": "node scripts/check-mongo.mjs",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "bundle:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist/lambda/index.js --external:@aws-sdk/* --alias:mongodb=mongodb/src --main-fields=module,main --tree-shaking=true --minify --sourcemap",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@dtapline/domain": "workspace:^",
    "@effect-aws/lambda": "^1.5.1",
    "@effect-aws/powertools-logger": "^1.5.1",
    "@effect/cluster": "^0.56.1",
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "@effect/rpc": "^0.73.0",
    "@effect/sql": "^0.49.0",
    "aws4": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "effect": "^3.19.15",
    "mongodb": "^7.0.0",
    "socks": "^2.8.7"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "esbuild": "^0.25.2"
  }
}
