# ===================================
# CloudMatrix Server Configuration
# ===================================

# MongoDB Connection
# ----------------------------------
# Production: Use MongoDB Atlas connection string
# Local: Use local MongoDB instance
MONGODB_URI=mongodb://localhost:27017/dtapline

# Server Configuration
# ----------------------------------
PORT=3000

# CORS Configuration
# ----------------------------------
# Comma-separated list of allowed origins
# For development, you can use http://localhost:5173 (Vite default)
# For production, use your actual frontend domain
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Default User (MVP - Hardcoded Authentication)
# ----------------------------------
# In the MVP version, we use a single hardcoded user for all operations.
# This will be replaced with proper authentication in a future version.
DEFAULT_USER_ID=default-user
DEFAULT_USER_EMAIL=team@company.com
DEFAULT_USER_NAME="Development Team"

# AWS Configuration (for Lambda deployment)
# ----------------------------------
# These are automatically provided by AWS Lambda environment
# Only needed if you're testing AWS integrations locally
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key
