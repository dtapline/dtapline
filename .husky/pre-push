# Skip gitleaks check in CI environments
if [ -n "$CI" ]; then
  echo "⏭️  Skipping Gitleaks check (running in CI)"
  exit 0
fi

echo "🔍 Running Gitleaks to check for secrets..."
pnpm gitleaks:staged || {
  echo "❌ Gitleaks detected secrets! Push blocked."
  echo "💡 Review the findings above and remove any secrets."
  exit 1
}
